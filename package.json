{
  "name": "lunaris",
  "version": "0.0.1",
  "private": true,
  "description": "LUNARIS — a hard-realism lunar colonization simulation & game",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @lunaris/web-client dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck && tsc --noEmit -p tsconfig.json",
    "schema-check": "vitest run tests/data",
    "gen:map": "tsx tools/gen-map.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@lunaris/sim-core": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
